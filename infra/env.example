# Demo-only environment values. Copy to a local .env file when needed.
# Do not put real secrets, real keys or personal data in this repository.

PROJECT_NAME=ebis-nacionalidad-ledger
DEMO_WALLET_MNEMONIC=test test test test test test test test test test test junk
CHAIN_ID=20260711
BESU_RPC_HTTP_PORT=8545
BESU_METRICS_PORT=9545

POSTGRES_DB=ebis_demo
POSTGRES_USER=ebis_demo
POSTGRES_PASSWORD=change-me-demo-only
# Host-side port only; change if 5434 is already used by another local Postgres.
POSTGRES_HOST_PORT=5434

API_PORT=8080
API_JWT_ISSUER=ebis-demo
# HS256 needs at least 32 bytes (256 bits); generate your own for local use, e.g.
# `openssl rand -base64 32`. Never reuse this placeholder value for anything real.
API_JWT_SECRET=replace-with-local-random-demo-secret
API_ALLOWED_ORIGINS=http://localhost:5173
SIWE_DOMAIN=localhost
SIWE_URI=http://localhost:5173
SIWE_CHAIN_ID=20260711

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
VITE_BESU_RPC_URL=http://localhost:8545
VITE_BESU_CHAIN_ID=20260711
VITE_SIWE_DOMAIN=localhost
VITE_SIWE_URI=http://localhost:5173
VITE_WALLETCONNECT_PROJECT_ID=ebis-local-dev

BESU_LOCAL_RPC_URL=http://127.0.0.1:8545
BESU_DEPLOYER_PRIVATE_KEY=

BLOCKSCOUT_PORT=4000
BLOCKSCOUT_API_PORT=4001
BLOCKSCOUT_BACKEND_TAG=latest
BLOCKSCOUT_FRONTEND_TAG=latest
BLOCKSCOUT_POSTGRES_PASSWORD=blockscout-demo-only
BLOCKSCOUT_SECRET_KEY_BASE=ebis-blockscout-local-secret-key-base-change-me-demo-only

PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_TRACES_SAMPLER_PROBABILITY=1.0
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-demo-only
