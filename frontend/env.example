# Copy to .env.local for local dev (gitignored). See infra/env.example for the
# docker-compose-wide defaults; override VITE_API_BASE_URL here if your local backend
# runs on a different port (e.g. 8081, see docs/evidencias/M6_BACKEND.md).
VITE_API_BASE_URL=http://localhost:8080

# Besu JSON-RPC endpoint, read directly from the browser via viem for on-chain values the
# backend does not expose as REST (e.g. the Euro Digital demo balance, an ERC-20 read).
# Matches BESU_LOCAL_RPC_URL in infra/env.example.
VITE_BESU_RPC_URL=http://127.0.0.1:8545
